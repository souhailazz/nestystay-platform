ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__Postgres=Host=127.0.0.1;Port=55432;Database=nestystay_dev;Username=nestystay;Password=nestystay
NESTYSTAY_ADMIN_TOKEN=replace-with-local-admin-token
NESTYSTAY_ADMIN_TOKEN_SHA256=replace-with-sha256-of-local-admin-token
NESTYSTAY_OPERATOR_TOKEN=replace-with-local-operator-token
NESTYSTAY_OPERATOR_TOKEN_SHA256=replace-with-sha256-of-local-operator-token
NESTYSTAY_WEBHOOK_SHARED_SECRET=dev-webhook-secret
Integrations__EkycPrimary=AlibabaCloud
Integrations__PaymentPrimary=Stripe
Integrations__StoragePrimary=CloudflareR2
Integrations__InsurancePrimary=InsuraGuest
Integrations__StripeSecretKey=replace-with-stripe-secret-key
Integrations__AlibabaEkycTransactionUrlBase=https://ekyc-provider.example/start
Integrations__CloudflareR2UploadUrlBase=https://r2-upload.example/upload
Integrations__InsuraGuestApiBaseUrl=https://api.insuraguest.example
Webhooks__SharedSecret=dev-webhook-secret
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
ALIBABA_EKYC_TRANSACTION_URL_BASE=https://ekyc-provider.example/start
CLOUDFLARE_R2_UPLOAD_URL_BASE=https://r2-upload.example/upload
